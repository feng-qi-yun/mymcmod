{
	"schemaVersion": 1,
	"id": "ddnet_mc",
	"version": "${version}",
	"name": "ddnet_mc",
	"description": "a mod making ddnet playable in minecraft",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/ddnet_mc/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"ddnet_mc.ddnet_mc"
		],
		"client": [
			"ddnet_mc.client.ddnet_mcClient"
		]
	},
	"mixins": [
		"ddnet_mc.mixins.json",
		{
			"config": "ddnet_mc.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*"
	}
}